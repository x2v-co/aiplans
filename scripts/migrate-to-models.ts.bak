#!/usr/bin/env tsx

import { supabaseAdmin } from './db/queries';

// Model mapping from product/plan names to model cards
const MODEL_TO_MODEL: Record<string, string> = {
  // ChatGPT
  'chatgpt-free': 'gpt-4o-mini',
  'chatgpt-plus': 'gpt-4o-mini',
  'chatgpt-pro': 'gpt-4o-mini',
  'chatgpt-team': 'gpt-4o-mini',

  // Claude
  'claude-pro': 'claude-sonnet-4.6',
  'claude-team': 'claude-sonnet-4.6',

  // Gemini
  'gemini-1.5-pro': 'gemini-3-pro',
  'gemini-3-flash': 'gemini-3-flash',
  'google-one-ai-premium': 'gemini-3-pro',

  // Minimax
  'minimax-m2.5': 'minimax-m2.5',
  'minimax-m2.1': 'minimax-m2.1',
  'minimax-m2.5-pro': 'minimax-m2.5',
  'minimax-global-free': 'minimax-m2.5',
  'minimax-global-lite': 'minimax-m2.1',
  'minimax-global-pro': 'minimax-m2.5',

  // GLM
  'glm-coding-lite': 'glm-4.7',
  'glm-coding-pro': 'glm-5',
  'glm-coding-max': 'glm-4.7',
  'glm-coding-team': 'glm-5',
  'z-ai-free': 'glm-4.7',
  'z-ai-lite': 'glm-5',
  'z-ai-pro': 'glm-4.7',

  // Z.AI
  'qwen-max': 'qwen-max',
  'qwen3.5-397b': 'qwen3.5-397b',

  // Kimi
  'kimi-k2.5-thinking': 'kimi-k2.5-thinking',
  'kimi-k2.5-instant': 'kimi-k2.5-instant',

  // ERNIE
  'ernie-bot-4-turbo': 'ernie-bot-4-turbo',

  // Seed
  'seed-2.0': 'seed-2.0',
  'seed-lite': 'seed-2.0',
  'seed-pro': 'seed-2.0',
};

async function main() {
  console.log('📊 MIGRATING PRODUCTS TO MODELS TABLE');
  console.log('='.repeat(70));

  // Get all products that have plans
  const { data: products } = await supabaseAdmin
    .from('products')
    .select(`
      id,
      name,
      slug,
      provider_id,
      benchmark_arena_elo,
      plans:plan_id (
        id,
        name,
        slug
      )
    `)
    .neq('type', 'subscription')
    .order('id');

  let created = 0;
  let skipped = 0;
  let errors = 0;

  for (const product of products || []) {
    if (!product.plans || product.plans.length === 0) {
      console.log(`  ⚠️  Product has no plans: ${product.name} (${product.slug})`);
      skipped++;
      continue;
    }

    const planSlug = product.plans?.[0]?.slug;
    if (!planSlug) {
      console.log(`  ⚠️  No plan for product: ${product.name}`);
      skipped++;
      continue;
    }

    const modelName = MODEL_TO_MODEL[planSlug];

    if (!modelName) {
      console.log(`  ⚠️  No model mapping for plan: ${planSlug}`);
      skipped++;
      continue;
    }

    // Check if model already exists
    const { data: existingModel } = await supabaseAdmin
      .from('models')
      .select('id')
      .eq('modelId', product.id);

    if (existingModel && existingModel.length > 0) {
      console.log(`  ✓ Model already exists: ${modelName}`);
      skipped++;
      continue;
    }

    // Get plan for card data
    const result = await supabaseAdmin
      .from('plans')
      .select(`
        id,
        tier,
        pricing_model,
        price,
        price_unit,
        context_window,
        tokens_per_minute,
        tokens_per_month,
        max_tokens_per_request,
        max_input_tokens,
        max_output_tokens,
        features
      `)
      .eq('slug', planSlug)
      .single();

    if (result.error || !result.data) {
      console.log(`  ❌ Plan not found: ${planSlug}`);
      errors++;
      continue;
    }

    const plan = result.data;

    // Create model card
    const cardData = {
      tier: plan?.tier || '',
      pricingModel: plan?.pricing_model || '',
      price: plan?.price || 0,
      priceUnit: plan?.price_unit || '',
      contextWindow: plan?.context_window || null,
      tokensPerMinute: plan?.tokens_per_minute || null,
      tokensPerMonth: plan?.tokens_per_month || null,
      maxTokensPerRequest: plan?.max_tokens_per_request || null,
      maxInputTokens: plan?.max_input_tokens || null,
      maxOutputTokens: plan?.max_output_tokens || null,
      features: plan?.features || [],
    };

    const { data: newModel, error } = await supabaseAdmin
      .from('models')
      .insert({
        modelName: modelName,
        modelId: product.id,
        modelCardId: plan?.id || null,
        organization: product.providers?.organization || '',
        author: product.providers?.name || '',
        benchmarkArenaElo: product.benchmark_arena_elo || null,
        cardData: cardData,
      })
      .select()
      .single();

    if (!error && newModel) {
      created++;
      console.log(`  ✅ Created model: ${modelName} (productId=${product.id}, planId=${plan?.id || null})`);
    } else {
      console.log(`  ❌ Failed to create model: ${modelName}`);
      errors++;
    }
  }

  console.log('\n' + '='.repeat(70));
  console.log('📊 MIGRATION SUMMARY');
  console.log('='.repeat(70));
  console.log(`✅ Models created: ${created}`);
  console.log(`⏭️  Skipped (already exist): ${skipped}`);
  console.log(`❌ Errors: ${errors}`);
  console.log('='.repeat(70));
}

main()
  .then(() => {
    console.log('\n✅ Migration completed!');
    process.exit(0);
  })
  .catch((e) => {
    console.error('Error:', e);
    process.exit(1);
  });
