  <script nonce="aqEILwghan9s91ZySFfF">
  function getSafeVersion() {
    var v = new URL(location.href).searchParams.get("efm_v") || new URL(location.href).searchParams.get("v");
    var versionRegex = /^\d+\.\d+\.\d+$/;
    if (v && versionRegex.test(v)) {
