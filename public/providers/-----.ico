  <script nonce="aqEILwghan9s91ZySFfF">
  function getCookie(name) {
    try {
      // 确保 name 是字符串且非空
      if (typeof name !== 'string' || name === '') {
        return null;
      }

      // 转义正则元字符（ES5 兼容）
      var escapedName = name.replace(/([.$?*|{}()[\]\\/+^])/g, '\\$1');

      // 构造正则：匹配以开头或分号+空白开头的 cookie
      var regex = new RegExp('(?:^|;\\s*)' + escapedName + '=([^;]*)');

      // 安全读取 document.cookie（某些安全上下文可能限制访问）
      var cookieString = document.cookie || '';

      var matches = cookieString.match(regex);
      if (matches && matches[1]) {
        return decodeURIComponent(matches[1]);
      }
    } catch (e) {
      // 任何错误（如正则语法问题、decodeURIComponent 失败等）都静默忽略
    }
    return null;
  }
  // 安全调用
  try {
    var noAds = getCookie('no_ads');
    if (noAds === 'true') {
      window.no_ads = true;
    }
  } catch (e) {
    // 即使设置 window.no_ads 出错也不影响页面
  }
</script> 
