  function getIsMobile() {
    var ua = (navigator.userAgent || '').toLowerCase();
    var uaMatch = /android|iphone|ipad|ipod|windows phone|mobile|blackberry|opera mini|opera mobi|ucbrowser|kindle|silk|webos/.test(ua);

